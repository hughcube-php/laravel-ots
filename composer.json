{
    "name": "hughcube/laravel-ots",
    "description": "",
    "license": "MIT",
    "authors": [
        {
            "name": "hugh.li",
            "email": "hugh.li@foxmail.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "aliyun/aliyun-tablestore-sdk-php": "<=5.1.3 || >=6.0.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "*",
        "phpstan/phpstan": "*",
        "orchestra/testbench": "*",
        "laravel/sanctum": "*",
        "hughcube/base": "*",
        "jenssegers/mongodb": "*",
        "mongodb/laravel-mongodb": "*"
    },
    "autoload": {
        "psr-4": {
            "HughCube\\Laravel\\OTS\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HughCube\\Laravel\\OTS\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HughCube\\Laravel\\OTS\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse -vvv --memory-limit=-1",
        "check-style": "phpcs -p --standard=PSR2 src/ -v",
        "fix-style": "phpcbf -p --standard=PSR2 src/ -v"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
